# Auto-normalize text endings.
*text = auto

# scripts to force lf on
*.py text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.hcl text eol=lf
*.pem text eol=lf
*.md text eol=lf
*.crt text eol=lf

# binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.zip binary
*.svg binary
*.pdf binary
*.exe binary

# windows files
*.bat text eol=crlf
*.ps1 text eol=crlf